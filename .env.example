GROQ_API_KEY=your_groq_api_key_here
# Optional: comma-separated list of keys for round-robin failover. If set,
# this takes priority over GROQ_API_KEY above. When a request hits a Groq
# rate limit (429), the client automatically retries with the next key in
# the list before giving up, so one exhausted key/account doesn't abort a
# batch run. See generator/config.py:get_api_keys / create_chat_completion.
# GROQ_API_KEYS=key_one,key_two,key_three
GEN_MODEL=llama-3.3-70b-versatile
JUDGE_MODEL=openai/gpt-oss-120b
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
